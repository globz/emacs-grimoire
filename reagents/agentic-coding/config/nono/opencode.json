{
  "meta": {
    "name": "opencode",
    "version": "1.4.3",
    "description": "OpenCode AI coding assistant",
    "author": "globz"
  },
  "workdir": {
    "access": "readwrite"
  },
  "security": {
    "groups": [
        "node_runtime",
        "unlink_protection",
        "user_caches_linux",
        "opencode_linux"          
    ]
  },
  "filesystem": {
    "allow": [
      "~/.config/opencode",
      "~/.cache/opencode",
      "~/.local/share/opencode",
      "~/.local/state/opencode",
      "~/.local/share/opentui"
    ],
    "read": [
       "~/.opencode",
       "~/.opencode/bin",
       "~/.local/share/pnpm"
    ],
    "allow_file": [
      "~/.cache/opencode/models.json",
      "~/.local/state/opencode/prompt-history.jsonl",
      "~/.opencode/package.json",
      "~/.cache/opencode/version"
    ]      
  },
  "network": {
    "block": false
  },
  "rollback": {
    "exclude_patterns": ["node_modules"],
    "exclude_globs": ["*.tmp.[0-9]*.[0-9]*"]
  },
  "interactive": true
}
