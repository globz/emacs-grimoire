{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "plan",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git *": "deny",
      "npm *": "deny",
      "rm *": "deny",
      "sudo": "deny",
      "su *": "deny",
      "dd *": "deny",
    },
  },
  "agent": {
    "build": {
      "mode": "primary",
    },
    "plan": {
      "mode": "primary",
    },
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "model": "chutes/Qwen/Qwen3-235B-A22B-Thinking-2507",
      "permission": {
        "skill": {
          "code-review": "allow"
        }
      }
    },
    "ux-designer": {
      "description": "UX/UI designer",
      "mode": "subagent",
      "model": "chutes/zai-org/GLM-4.6V",
      "temperature": 0.5,
      "permission": {
        "skill": {
          "ux-design": "allow"
        }
      }
    }
  }    
}
